; ---- Browse Regen Media — directory background ----
[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\Browse Regen Media]
@="Browse Regen Media"

[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\Browse Regen Media\command]
@="cmd /c start https://media-manager.dev.regendevcorp.com"
