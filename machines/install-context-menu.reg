Windows Registry Editor Version 5.00

; Regen Media — Upload context menu for image files
; Adds "Upload to Regen Media" to right-click menu for common image formats
; Uses HKEY_CURRENT_USER — no admin required

; ---- .jpg ----
[HKEY_CURRENT_USER\Software\Classes\SystemFileAssociations\.jpg\shell\Upload to Regen Media]
"MuiVerb"="Upload to Regen Media"
"Icon"="%SystemRoot%\\System32\\imageres.dll,-70"

[HKEY_CURRENT_USER\Software\Classes\SystemFileAssociations\.jpg\shell\Upload to Regen Media\command]
@="powershell.exe -ExecutionPolicy Bypass -WindowStyle Hidden -File \"C:\\Dev\\regen-root\\scripts\\upload-to-media.ps1\" \"%1\""

