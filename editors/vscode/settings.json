{
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontFamily": "'Cascadia Code', 'Fira Code', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.wordWrap": "off",
  "editor.minimap.enabled": false,
  "editor.rulers": [100],
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlineSuggest.enabled": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,

  "terminal.integrated.defaultProfile.windows": "SV",
  "terminal.integrated.profiles.windows": {
    "SV": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","sv"],
      "icon": "symbol-namespace",
      "color": "terminal.ansiGreen",
      "env": { "CELL_ROLE": "sv" }
    },
    "Portal": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","cell-portal"],
      "icon": "globe",
      "color": "terminal.ansiBlue",
      "env": { "CELL_ROLE": "cell-portal" }
    },
    "Data": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","cell-data"],
      "icon": "database",
      "color": "terminal.ansiCyan",
      "env": { "CELL_ROLE": "cell-data" }
    },
    "CS2": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","cell-cs2"],
      "icon": "beaker",
      "color": "terminal.ansiMagenta",
      "env": { "CELL_ROLE": "cell-cs2" }
    },
    "Mktg": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","cell-mktg"],
      "icon": "megaphone",
      "color": "terminal.ansiYellow",
      "env": { "CELL_ROLE": "cell-mktg" }
    },
    "Infra": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","cell-infra"],
      "icon": "server",
      "color": "terminal.ansiWhite",
      "env": { "CELL_ROLE": "cell-infra" }
    },
    "Specialist": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-ExecutionPolicy", "Bypass", "-File", "C:\\Dev\\regen-root\\scripts\\cell-init.ps1","specialist"],
      "icon": "search",
      "color": "terminal.ansiRed",
      "env": { "CELL_ROLE": "specialist" }
    },
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.4,
  "terminal.integrated.fontFamily": "'Cascadia Code', Consolas, monospace",
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.location": "right",
  "terminal.integrated.persistentSessionReviveProcess": "never",

  "explorer.compactFolders": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, pnpm-lock.yaml, yarn.lock, .npmrc, .nvmrc, turbo.json, .prettierrc*, .eslintrc*, .eslintignore, .prettierignore",
    "tsconfig.json": "tsconfig.*.json",
    "next.config.*": "next-env.d.ts, next-env.d.mts, .next, out",
    "*.env": ".env.*, .env.local, .env.development, .env.production",
    "*.ts": "${capture}.test.ts, ${capture}.spec.ts, ${capture}.d.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.spec.tsx",
    "README.md": "CHANGELOG.md, LICENSE, .gitignore, .gitattributes, .editorconfig",
    "supabase/config.toml": "supabase/seed.sql, supabase/schema.sql"
  },
  "explorer.sortOrder": "foldersNestsFiles",

  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/.turbo": true,
    "**/.vercel": true,
    "**/*.js.map": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true,
    "**/.turbo": true,
    "pnpm-lock.yaml": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/dist/**": true
  },

  "workbench.colorTheme": "One Dark Pro Darker",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabSizing": "shrink",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.sideBar.location": "left",
  "workbench.statusBar.visible": true,
  "workbench.activityBar.location": "default",
  "breadcrumbs.enabled": true,

  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.defaultBranchName": "main",
  "git.pruneOnFetch": true,
  "git.openRepositoryInParentFolders": "always",
  "git.inputValidationSubjectLength": 72,

  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.tsdk": "node_modules/typescript/lib",
  "javascript.updateImportsOnFileMove.enabled": "always",

  "[typescript]":      { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]":      { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]":            { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]":           { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]":             { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]":        { "editor.defaultFormatter": "esbenp.prettier-vscode", "editor.wordWrap": "on" },
  "[sql]":             { "editor.defaultFormatter": "mtxr.sqltools" },

  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)",  "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },

  "npm.packageManager": "pnpm",
  "eslint.workingDirectories": [
    { "pattern": "apps/*/" },
    { "pattern": "packages/*/" }
  ],
  "eslint.enable": true,
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "sqltools.useNodeRuntime": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "problems.showCurrentInStatus": true,
  "extensions.ignoreRecommendations": false,
  "security.workspace.trust.untrustedFiles": "open"
}
