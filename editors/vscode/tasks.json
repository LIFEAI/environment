{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "turbo: dev (all apps)",
      "type": "shell",
      "command": "pnpm turbo dev",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "shared", "showReuseMessage": false },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "turbo: build (all)",
      "type": "shell",
      "command": "pnpm turbo build",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "turbo: typecheck (all)",
      "type": "shell",
      "command": "pnpm turbo typecheck",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "turbo: lint (all)",
      "type": "shell",
      "command": "pnpm turbo lint",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "turbo: test (all)",
      "type": "shell",
      "command": "pnpm turbo test",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "prt: dev",
      "type": "shell",
      "command": "pnpm dev",
      "options": { "cwd": "${workspaceFolder}/apps/prt" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "apps" },
      "problemMatcher": []
    },
    {
      "label": "prt: build",
      "type": "shell",
      "command": "pnpm build",
      "options": { "cwd": "${workspaceFolder}/apps/prt" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "apps" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "supabase: generate types",
      "type": "shell",
      "command": "pnpm supabase gen types typescript --project-id uvojezuorjgqzmhhgluu > src/types/supabase.ts",
      "options": { "cwd": "${workspaceFolder}/packages/supabase" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "supabase: db push (dev)",
      "type": "shell",
      "command": "pnpm supabase db push",
      "options": { "cwd": "${workspaceFolder}/packages/supabase" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "supabase: migration new",
      "type": "shell",
      "command": "pnpm supabase migration new ${input:migrationName}",
      "options": { "cwd": "${workspaceFolder}/packages/supabase" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "pnpm: install (root)",
      "type": "shell",
      "command": "pnpm install",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "pnpm: clean all node_modules",
      "type": "shell",
      "command": "pnpm -r exec -- node -e \"require('fs').rmSync('node_modules',{recursive:true,force:true})\"",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "claude: new session",
      "type": "shell",
      "command": "claude",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "ai" },
      "problemMatcher": []
    },
    {
      "label": "startup: open dev setup",
      "type": "shell",
      "command": "code ${workspaceFolder}/DEV-SETUP.md",
      "presentation": { "reveal": "never" },
      "problemMatcher": [],
      "runOptions": { "runOn": "folderOpen" }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Migration name (snake_case)",
      "default": "new_migration"
    }
  ]
}
