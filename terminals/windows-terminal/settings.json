{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",

  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "copyOnSelect": true,
  "copyFormatting": "all",
  "firstWindowPreference": "persistedWindowLayout",
  "initialRows": 40,
  "showTabsFullscreen": true,
  "theme": "dark",
  "wordDelimiters": " /\\()\"'-.,:;<>~!@#$%^&*|+=[]{}~?│",

  "newTabMenu": [{ "type": "remainingProfiles" }],

  "actions": [
    { "command": "find",                                                    "id": "User.find" },
    { "command": { "action": "splitPane", "split": "auto", "splitMode": "duplicate" }, "id": "User.splitPane.A6751878" },
    { "command": { "action": "copy", "singleLine": false },                 "id": "User.copy.644BA8F2" },
    { "command": { "action": "sendInput", "input": "\n" },                  "id": "User.sendInput.shiftenter" }
  ],

  "keybindings": [
    { "id": "Terminal.DuplicatePaneRight",   "keys": "ctrl+alt+v" },
    { "id": "Terminal.MoveFocusLeft",        "keys": "ctrl+alt+left" },
    { "id": "Terminal.MoveFocusRight",       "keys": "ctrl+alt+right" },
    { "id": "Terminal.MoveFocusUp",          "keys": "ctrl+alt+up" },
    { "id": "Terminal.MoveFocusDown",        "keys": "ctrl+alt+down" },
    { "id": "Terminal.DuplicatePaneDown",    "keys": "ctrl+shift+h" },
    { "id": "Terminal.TogglePaneZoom",       "keys": "ctrl+shift+z" },
    { "id": "Terminal.PasteFromClipboard",   "keys": "ctrl+v" },
    { "id": "Terminal.ClosePane",            "keys": "ctrl+shift+w" },
    { "id": "Terminal.ResizePaneLeft",       "keys": "ctrl+alt+shift+left" },
    { "id": "Terminal.ResizePaneRight",      "keys": "ctrl+alt+shift+right" },
    { "id": "User.find",                     "keys": "ctrl+shift+f" },
    { "id": "User.copy.644BA8F2",            "keys": "ctrl+c" },
    { "id": "User.splitPane.A6751878",       "keys": "alt+shift+d" },
    { "id": "User.sendInput.shiftenter",     "keys": "shift+enter" },
    { "id": null,                            "keys": "ctrl+enter" },
    { "id": null,                            "keys": "enter" },
    { "id": null,                            "keys": "win+h" }
  ],

  "profiles": {
    "defaults": {
      "antialiasingMode": "cleartype",
      "bellStyle": "none",
      "colorScheme": "Dimidium",
      "cursorShape": "bar",
      "font": {
        "cellHeight": "1.2",
        "cellWidth": "0.6",
        "face": "Consolas",
        "size": 12,
        "weight": "normal"
      },
      "historySize": 50000,
      "padding": "12",
      "scrollbarState": "hidden"
    },

